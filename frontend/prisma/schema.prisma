generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(uuid()) @db.Uuid
  name             String               @db.VarChar(120)
  email            String               @unique @db.VarChar(200)
  passwordHash     String               @map("password_hash")
  role             String               @default("user") @db.VarChar(30)
  isActive         Boolean              @default(true) @map("is_active")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @default(now()) @map("updated_at")
  cards            Card[]
  categories       Category[]
  monthlyIncomes   MonthlyIncome[]
  expensePurchases ExpensePurchase[]
  installments     ExpenseInstallment[]
  invoicePayments  CardInvoicePayment[]
  cashFlows        CashFlow[]

  @@map("users")
}

model Card {
  id              String                 @id @default(uuid()) @db.Uuid
  userId          String                 @map("user_id") @db.Uuid
  name            String                 @db.VarChar(120)
  invoiceDueDay   Int                    @map("invoice_due_day")
  limitAmount     Decimal                @map("limit_amount") @db.Decimal(14, 2)
  brand           String                 @db.VarChar(60)
  issuingBank     String                 @map("issuing_bank") @db.VarChar(120)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @default(now()) @map("updated_at")
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases       ExpensePurchase[]
  installments    ExpenseInstallment[]
  invoicePayments CardInvoicePayment[]

  @@map("cards")
}

model Category {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  name       String            @db.VarChar(120)
  type       String            @db.VarChar(20)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @map("updated_at")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes    MonthlyIncome[]
  purchases  ExpensePurchase[]

  @@unique([userId, name, type])
  @@map("categories")
}

model MonthlyIncome {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  referenceMonth DateTime  @map("reference_month") @db.Date
  description    String    @db.VarChar(255)
  amount         Decimal   @db.Decimal(14, 2)
  receivedDate   DateTime  @map("received_date") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category  @relation(fields: [categoryId], references: [id])

  @@map("monthly_incomes")
}

model ExpensePurchase {
  id                 String               @id @default(uuid()) @db.Uuid
  userId             String               @map("user_id") @db.Uuid
  cardId             String               @map("card_id") @db.Uuid
  categoryId         String               @map("category_id") @db.Uuid
  referenceMonth     DateTime             @map("reference_month") @db.Date
  expenseDescription String               @map("expense_description") @db.VarChar(255)
  totalAmount        Decimal              @map("total_amount") @db.Decimal(14, 2)
  installments       Int
  purchaseDate       DateTime             @map("purchase_date") @db.Date
  storeName          String               @map("store_name") @db.VarChar(255)
  productDescription String               @map("product_description")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @default(now()) @map("updated_at")
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  card               Card                 @relation(fields: [cardId], references: [id])
  category           Category             @relation(fields: [categoryId], references: [id])
  installmentsItems  ExpenseInstallment[]

  @@map("expense_purchases")
}

model ExpenseInstallment {
  id                String                   @id @default(uuid()) @db.Uuid
  purchaseId        String                   @map("purchase_id") @db.Uuid
  userId            String                   @map("user_id") @db.Uuid
  cardId            String                   @map("card_id") @db.Uuid
  installmentNumber Int                      @map("installment_number")
  totalInstallments Int                      @map("total_installments")
  referenceMonth    DateTime                 @map("reference_month") @db.Date
  amount            Decimal                  @db.Decimal(14, 2)
  status            String                   @default("pending") @db.VarChar(20)
  paidAt            DateTime?                @map("paid_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @default(now()) @map("updated_at")
  purchase          ExpensePurchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card              Card                     @relation(fields: [cardId], references: [id])
  paymentItems      CardInvoicePaymentItem[]

  @@unique([purchaseId, installmentNumber])
  @@map("expense_installments")
}

model CardInvoicePayment {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  cardId          String                   @map("card_id") @db.Uuid
  referenceMonth  DateTime                 @map("reference_month") @db.Date
  paidTotalAmount Decimal                  @map("paid_total_amount") @db.Decimal(14, 2)
  paymentDate     DateTime                 @map("payment_date") @db.Date
  notes           String?
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @default(now()) @map("updated_at")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            Card                     @relation(fields: [cardId], references: [id])
  items           CardInvoicePaymentItem[]

  @@map("card_invoice_payments")
}

model CardInvoicePaymentItem {
  id                   String             @id @default(uuid()) @db.Uuid
  paymentId            String             @map("payment_id") @db.Uuid
  expenseInstallmentId String             @map("expense_installment_id") @db.Uuid
  amount               Decimal            @db.Decimal(14, 2)
  createdAt            DateTime           @default(now()) @map("created_at")
  payment              CardInvoicePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  installment          ExpenseInstallment @relation(fields: [expenseInstallmentId], references: [id])

  @@unique([paymentId, expenseInstallmentId])
  @@map("card_invoice_payment_items")
}

model CashFlow {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  movementType   String   @map("movement_type") @db.VarChar(20)
  originType     String   @map("origin_type") @db.VarChar(40)
  originId       String   @map("origin_id") @db.Uuid
  referenceMonth DateTime @map("reference_month") @db.Date
  movementDate   DateTime @map("movement_date") @db.Date
  amount         Decimal  @db.Decimal(14, 2)
  description    String   @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cash_flows")
}
